# Optional: override where the SQLite database file is stored.
# Default: seo_audits.db in the project root directory.
# DB_PATH=/absolute/path/to/your/seo_audits.db

# Optional: set to "true" to disable real URL fetching (use mock data instead)
MOCK_MODE=false
# Optional: OpenAI API key for live AI visibility testing
# Get your key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
OPENAI_API_KEY=sk-....